# ============================================================
#  Sprenses Otel Yönetim Sistemi — Ortam Değişkenleri Şablonu
# ============================================================
# Bu dosyayı `.env` olarak kopyalayın ve gerçek değerlerle doldurun:
#   cp .env.example .env
# `.env` dosyası ASLA git'e eklenmez (.gitignore'da hariç tutulmuştur).
# Gerçek gizli değerleri bu şablona YAZMAYIN.

# --- Veritabanı ---
# PostgreSQL bağlantı URL'si
DATABASE_URL=postgresql://KULLANICI:SIFRE@127.0.0.1:5432/sprenses

# --- JWT / Kimlik Doğrulama ---
# SECRET_KEY: en az 32 karakter, kriptografik rastgele değer olmalı.
# Üretmek için: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=BURAYA_EN_AZ_32_KARAKTERLIK_RASTGELE_DEGER
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Web Push (VAPID) ---
# Üretmek için: bkz. docs/modules/push-bildirim.md
VAPID_PRIVATE_KEY=BURAYA_VAPID_PRIVATE_KEY
VAPID_PUBLIC_KEY=BURAYA_VAPID_PUBLIC_KEY
VAPID_MAILTO=mailto:ornek@sprenses.com

# --- CORS ---
# İzin verilen origin'ler (virgülle ayrılmış)
CORS_ORIGINS=https://sprenses.com

# --- Public taban URL (e-posta bağlantıları: teyit vb.) ---
PUBLIC_BASE_URL=https://sprenses.com

# --- Internal API gizli anahtarı ---
# Üretmek için: python -c "import secrets; print(secrets.token_urlsafe(48))"
INTERNAL_SECRET=BURAYA_EN_AZ_32_KARAKTERLIK_RASTGELE_DEGER

# --- Travelpayouts / Aviasales (uçak rezervasyon — opsiyonel) ---
TRAVELPAYOUTS_MARKER=
TRAVELPAYOUTS_TOKEN=

# --- SMTP / Giden E-posta (bildirim — opsiyonel) ---
# TurkTicaret.net kurumsal e-posta. SMTP_PASSWORD boşsa e-posta gönderimi kapalıdır.
# Port 465 → SMTP_USE_SSL=true · Port 587 → SMTP_USE_SSL=false (STARTTLS)
SMTP_HOST=smtp.turkticaret.net
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=bilgi@sprenses.com
SMTP_PASSWORD=BURAYA_EPOSTA_KUTU_SIFRESI
SMTP_FROM_NAME=Sprenses Otel

# Yapı Kredi API Portal (Account Transaction List — banka hesap hareketleri, opsiyonel)
# YKB_CLIENT_SECRET boşsa özellik devre dışıdır. Değerler apiportal.yapikredi.com.tr
# üzerinde oluşturulan uygulamadan alınır. Token URL portaldaki "Authorization" sayfasındadır.
YKB_TOKEN_URL=https://api.yapikredi.com.tr/auth/oauth/v2/token
YKB_CLIENT_ID=
YKB_CLIENT_SECRET=
YKB_SCOPE=oob
YKB_LOOKBACK_DAYS=7


# QNB Açık Bankacılık API (Hesap İşlemleri / Hesap Özeti — banka hesap hareketleri)
# QNB_CLIENT_SECRET boşsa özellik devre dışıdır. Değerler developer.qnb.com.tr
# üzerinden uygulama oluşturularak alınır. Başvuru kurumsal internet bankacılığından
# yapılır, token e-posta ile gönderilir. Sürüm 2 (account-statement) güncel servistir.
QNB_TOKEN_URL=https://sandbox-api.qnb.com.tr/token
QNB_BASE_URL=https://sandbox-api.qnb.com.tr/v0/account-statement
QNB_CLIENT_ID=
QNB_CLIENT_SECRET=
QNB_GRANT_TYPE=client_credentials
QNB_LOOKBACK_DAYS=7


# Garanti BBVA API (Account Transactions / Electronic Bank Statement — banka hesap hareketleri)
# GARANTI_CLIENT_SECRET boşsa özellik devre dışıdır. Değerler developers.garantibbva.com.tr
# üzerinde App/Organizasyon oluşturup API seçilerek alınır. Önce Sandbox'ta test edilir,
# sonra Production erişimi talep edilir. Endpoint: /balancesandmovements/.../gettransactions
GARANTI_TOKEN_URL=https://api.garantibbva.com.tr/auth/oauth/v2/token
GARANTI_BASE_URL=https://apis.garantibbva.com.tr/balancesandmovements/accountinformation/transaction/v1
GARANTI_CLIENT_ID=
GARANTI_CLIENT_SECRET=
GARANTI_GRANT_TYPE=client_credentials
GARANTI_LOOKBACK_DAYS=7


# Halkbank hesap hareketleri — Kobaküs KWAP açık bankacılık aggregator (AIS)
# Halkbank'a doğrudan değil, Kobaküs tek API'si (KWAP) üzerinden bağlanılır (kobakus.com).
# Erişim: ıslak imzalı talep formu + IP whitelisting gerekir; ayrı KWAP kullanıcısı tanımlanır.
# Kimlik OAuth değil, POST gövdesinde firmCode/password/channelCode ile yapılır.
# Hesap hareketleri: requestMethod=Transactions + startDate/endDate (Y-m-d H:i:s).
# KOBAKUS_PASSWORD boşsa özellik devre dışıdır. Halkbank hesapları yanıtta BankCode ile ayrılır.
KOBAKUS_API_URL=https://app.kobakus.com/webservice/BankPaymentList.php
KOBAKUS_FIRM_CODE=
KOBAKUS_PASSWORD=
KOBAKUS_CHANNEL_CODE=
KOBAKUS_HALKBANK_EFT_CODE=0012
KOBAKUS_LOOKBACK_DAYS=7
